{
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-news",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/weekly-coops",
      "schedule": "0 22 * * 1"
    }
  ]
}
