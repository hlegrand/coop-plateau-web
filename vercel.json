{
  "installCommand": "echo skipping npm install",
  "buildCommand": "echo done",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron?action=daily-news",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron?action=weekly-coops",
      "schedule": "0 22 * * 1"
    }
  ]
}
